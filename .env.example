# Eight (8card.net)
EIGHT_EMAIL=your-email@example.com
EIGHT_PASSWORD=your-password

# Microsoft Graph API (Azure AD App Registration)
MS_CLIENT_ID=your-azure-app-client-id
MS_TENANT_ID=common

# Internal app auth (optional)
# Shared password mode:
# APP_SHARED_PASSWORD=your-internal-password
# APP_ALLOWED_USERS=yamanaka,sato,suzuki
#
# Per-user password mode:
# APP_USER_PASSWORDS={"yamanaka":"pass1","sato":"pass2"}

# Playwright
HEADLESS=true
